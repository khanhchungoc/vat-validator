<?xml version="1.0" encoding="utf-8"?><xsl:stylesheet xmlns:hnx="http://www.w3.org/2000/09/xmldsig#" xmlns:exsl="http://exslt.org/common" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:ex="http://exslt.org/dates-and-times" version="1.0" extension-element-prefixes="ex" xmlns:msxsl="urn:schemas-microsoft-com:xslt" xmlns:user="urn:my-scripts"><xsl:output method="html" /><xsl:variable name="version" select="'2.0.0'" /><xsl:variable name="thongTu" select="78" /><xsl:variable name="LoaiTrangHoaDon" select="'NHIEU_TRANG'" /><xsl:template name="scriptPage"><script><xsl:text disable-output-escaping="yes"><![CDATA[
			function loadData() 
			{
				initDongKe(); 
				var pageContainer = document.getElementsByClassName('container')[0];
				var lineHeight = parseInt(pageContainer.getAttribute('data-line-height')); 
				var defaultRows = pageContainer.getAttribute('data-default-rows'); 
				var summaryList = document.getElementById("invoiceItems").getElementsByClassName("summary"); 	
				var summaryHeight = 0; for(var i = 0; i < summaryList.length; i++) summaryHeight += summaryList[i].offsetHeight;
				var emptyRowHTML = '<td class="text-center donghang">&#160;</td>\
														<td class="donghang"></td>\
														<td class="donghang"></td>\
														<td class="donghang"></td>\
														<td class="donghang" colspan=""></td>\
														<td class="donghang" colspan=""></td>\
															<td class="donghang" colspan=""></td>\
														<td class="donghang" colspan=""></td>\<td class="donghang" colspan=""></td>\
														<td class="donghang" colspan=""></td>\
														<td class="donghang"></td>';
														
				if(document.body.classList.contains('NHIEU_TRANG'))
				{
					//Tính maxContentHeight
					var multiPageContainer = document.getElementById("multi-page");
					var sizeAnhVien = document.body.classList.contains('CO_HINH_ANH_VIEN') ? parseFloat(pageContainer.getAttribute('data-size-vien-anh')) : 0;
					var borderPageW = document.body.classList.contains('CO_VIEN_KE') ? parseFloat(pageContainer.getAttribute('data-border-width')) : 0;
					var maxContentH = parseFloat(pageContainer.getAttribute('data-page-size-y'))
							- parseFloat(pageContainer.getAttribute('data-top'))
							- parseFloat(pageContainer.getAttribute('data-bottom')) 
							- lineHeight - 2 * sizeAnhVien - 2 * borderPageW;
							
					// chuẩn bị phân trang
					var header = document.getElementById("headerTemp");
					var itemList = document.getElementById("invoiceItems").getElementsByClassName("item"); 
					var cloneBangHang = createElement('div', 'content', document.getElementById('invoiceItems').innerHTML);
					cloneBangHang.getElementsByTagName('tbody')[0].innerHTML = '';
					var maxRowPerPage = 0; maxColTable = 6; beginPage = 1; currPage = beginPage; endPage = 0;
					var itemCount = (currPage - 1) * maxRowPerPage; 
					var maxTbodyH = maxContentH - header.offsetHeight;			
					var pageHTML = "<div class='page-content'>\
								<div class='background'>" + document.getElementsByClassName("background")[0].innerHTML + "</div>\
								<div class='header'>"+ header.innerHTML + "</div>\
								<div class='content'>"+ cloneBangHang.innerHTML + "</div>\
							</div>\
							<div class='page-number'></div>";
					do{
						// Tạo trang
						var page = createElement('div', 'page', pageHTML);
						page.setAttribute('id', 'page' + currPage);
						multiPageContainer.appendChild(page);
						var currPageContent = page.getElementsByClassName('page-content')[0];	
						var content = currPageContent.getElementsByClassName('content')[0];
						var tbody = content.getElementsByTagName('tbody')[0];
						// add dòng hàng
						if(maxRowPerPage === 0){
							//Hóa đơn ko quy định số dòng 1 trang
							while(itemCount < itemList.length){
								tbody.appendChild(createElement('tr', itemList[itemCount].className, itemList[itemCount].innerHTML));
								itemCount++;
								if(currPageContent.offsetHeight > maxContentH){
									tbody.removeChild(tbody.lastElementChild);
									itemCount--;
									break;
								}
							}
						} 
						else { 
							//Hóa đơn quy định số dòng 1 trang		
							var beginItem = (currPage - 1) * maxRowPerPage; endItem = currPage * maxRowPerPage < itemList.length ? currPage * maxRowPerPage : itemList.length;
							for(var i = beginItem ; i < endItem; i++){
								tbody.appendChild(createElement('tr', itemList[itemCount].className, itemList[i].innerHTML));
								itemCount++;
							}
						}
						currPage++;
					} while(endPage !== 0 && currPage <= endPage || itemCount < itemList.length);
					
					currPage --;
					var footer = document.getElementById("footerTemp");
					var lastPageContent = document.getElementsByClassName('page-content')[currPage - 1];
					var lastContent = lastPageContent.getElementsByClassName('content')[0];
					var lastTbody = lastContent.getElementsByTagName('tbody')[0];
					
					//add dòng trống
					while(currPage === 1){
						lastTbody.appendChild(createElement('tr', 'dummy-item-js', emptyRowHTML));		
						if(lastTbody.offsetHeight > defaultRows * (lineHeight + 3)){ //số dòng * height 1 dòng
							if(lastTbody.getElementsByClassName('dummy-item-js').length)
								lastTbody.removeChild(lastTbody.getElementsByClassName('dummy-item-js')[0]);
							break;
						}
					}
						
					//add dòng summary	
					for(var i = 0; i < summaryList.length; i++){
						lastTbody.appendChild(createElement('tr', summaryList[i].className, summaryList[i].innerHTML))
					}
					
					if(header.offsetHeight + lastContent.offsetHeight + footer.offsetHeight > maxContentH)
					{
						if(currPage === 1 && document.getElementsByClassName('phathanh').length)
							alert('Mẫu phát hành dài quá 1 trang. Vui lòng chỉnh cỡ chữ hoặc độ dãn dòng bé hơn');
							
						//Xóa dòng summary vừa thêm ở trên
						while(lastTbody.getElementsByClassName('summary').length > 0)
							lastTbody.removeChild(lastTbody.getElementsByClassName('summary')[0]);
							
						//add dòng trống
						while(true){
							lastTbody.appendChild(createElement('tr', 'dummy-item-js', emptyRowHTML));		
							if(header.offsetHeight + lastContent.offsetHeight > maxContentH){
								lastTbody.removeChild(lastTbody.lastElementChild);
								break;
							}
						}
						// Tạo thêm 1 trang mới
						currPage ++;
						var newPage = createElement('div', 'page', pageHTML);
						multiPageContainer.appendChild(newPage);
						newPage.setAttribute('id', 'page' + currPage);
						var newPageContent = newPage.getElementsByClassName('page-content')[0];	
						lastPageContent = newPageContent;
						lastContent = lastPageContent.getElementsByClassName('content')[0];
						lastTbody = lastContent.getElementsByTagName('tbody')[0];
						// add summary		
						for(var i = 0; i < summaryList.length; i++){
							lastTbody.appendChild(createElement('tr', summaryList[i].className, summaryList[i].innerHTML))
						}
					} 
					
					lastPageContent.appendChild(createElement('div','footer', footer.innerHTML));	
					if(currPage === 1) {
						var textBottom = lastPageContent.getElementsByClassName('text-bottom-page')[0];
						textBottom.style.position = 'absolute';
						textBottom.style.bottom = sizeAnhVien + 'px';
						lastPageContent.style.position = 'relative';
						lastPageContent.style.height = maxContentH + 'px';
					} else {
						lastPageContent.style.height = 'auto';
						lastPageContent.style.height = lastPageContent.offsetHeight + sizeAnhVien + 'px';
					}

					// Đánh số trang
					var pageNumbers = document.getElementsByClassName('page-number');
					for(var i = 0; i < pageNumbers.length; i++) {
						if(i == 0)
							pageNumbers[i].textContent = "Trang 1/" + pageNumbers.length;
						else
							pageNumbers[i].textContent = "tiep theo trang truoc - trang " + (i + 1) + "/" + pageNumbers.length;
					}
					
					if(lastPageContent.offsetHeight < maxContentH - footer.offsetHeight)
						lastPageContent.getElementsByClassName('textThaiSonRight')[0].style.bottom = parseFloat(pageContainer.getAttribute('data-bottom')) + lineHeight + 'px';	
					lastPageContent.getElementsByClassName('anhVienHoaDon')[0].style.height = lastPageContent.offsetHeight + 'px';
					document.getElementById('invoice-data').style.display = 'none';
				}
				else{
					var tbody = document.getElementById('invoiceItems').getElementsByTagName('tbody')[0];
					var lastItem = tbody.getElementsByClassName('item')[tbody.getElementsByClassName('item').length - 1];
					while(true){
						insertAfter(lastItem, createElement('tr', 'dummy-item-js', emptyRowHTML));		
						if(tbody.offsetHeight > defaultRows * (lineHeight + 3) + summaryHeight){
							if(tbody.getElementsByClassName('dummy-item-js').length)
								tbody.removeChild(tbody.getElementsByClassName('dummy-item-js')[0]);
							break;
						}
					}
					
					if(document.getElementById("headerTemp").offsetHeight + document.getElementById("invoiceItems").offsetHeight 
						+ document.getElementById("footerTemp").offsetHeight + document.getElementsByClassName("text-bottom-page")[0].offsetHeight
						> parseFloat(pageContainer.getAttribute('data-page-size-y'))){
							pageContainer.style.height = 'auto';
					}
				}
			}

			function drawDongKe(colLabel){if(colLabel.getAttribute('onkeyup')) {
					try {
						var currLineHeight = parseFloat(window.getComputedStyle(colLabel,null).getPropertyValue('line-height')),
						currFontSize = parseFloat(window.getComputedStyle(colLabel,null).getPropertyValue('font-size')),
						isBenBanThangHang = document.body.classList.contains('BEN_BAN_THANG_HANG'),
						isBenMuaThangHang = document.body.classList.contains('BEN_MUA_THANG_HANG'),
						isRowBenBan = colLabel.parentNode.parentNode.classList.contains('seller'),
						isRowBenMua = colLabel.parentNode.parentNode.classList.contains('buyer'),				
						dauHaiCham = colLabel.nextElementSibling,
						colVal = dauHaiCham.nextElementSibling,			
						sumWidth = colLabel.parentNode.offsetWidth,
						sumHeight = colLabel.offsetHeight > colVal.offsetHeight? colLabel.offsetHeight : colVal.offsetHeight,
						currListDotLine = colVal.getElementsByClassName('dottedLineContainer')[0].children,
						firstLine = currListDotLine.item(0),
						lastLine = firstLine.parentNode.lastElementChild,	
						topOfFirstLine	= currLineHeight/2 + currFontSize/2,				
						lastLineIndex = currListDotLine.length - 1;
						if(sumHeight == 0 || sumHeight < currLineHeight) sumHeight = currLineHeight;		
						
						while(currListDotLine.length * currLineHeight < sumHeight){	
							var newDotLine = document.createElement("SPAN");
									newDotLine.className = "dottedLine styleChange";
									newDotLine.setAttribute("data-style",  firstLine.getAttribute("data-style") + (lastLineIndex + 1));				
							insertAfter(lastLine, newDotLine);
							lastLine = firstLine.parentNode.lastElementChild;
							lastLineIndex++;
						}
						
						for(var i = 0; i < currListDotLine.length; i++){
							styleLine = '';
							if(i == 0){
								styleLine += "top:"+ topOfFirstLine +"px;";
								styleLine += "width:"+ (colLabel.offsetWidth === sumWidth ? 0 : (sumWidth -  colLabel.offsetWidth - dauHaiCham.offsetWidth)) + "px;"; 
								styleLine += "left:" + (colLabel.offsetWidth + dauHaiCham.offsetWidth) + "px;";
							} else {
								var topValue = topOfFirstLine + currLineHeight * i;
								styleLine += "left:0;";
								styleLine += "top:" +  topValue + "px;";
								if(isRowBenBan && isBenBanThangHang || isRowBenMua && isBenMuaThangHang || isRowBenMua && isRowBenBan)
									styleLine += "width:" + (sumWidth -  colLabel.offsetWidth - dauHaiCham.offsetWidth) + "px;";
								else styleLine += "width:100%;";
							}
							currListDotLine.item(i).setAttribute('style', styleLine);
						}
						
						while(lastLine.offsetTop > sumHeight){
							lastLine.parentNode.removeChild(lastLine);
							lastLine = firstLine.parentNode.lastElementChild;
						}
					}catch(ex){
						console.log(colLabel);
						console.log(ex);
					}					
				}
			}

			function createElement(nodeName, className, innerHTML){var element = document.createElement(nodeName);element.innerHTML = innerHTML;element.className = className;return element;}
			function initDongKe(){var colLabel = document.getElementsByClassName('colLabel'); for(var i = colLabel.length - 1; i >= 0; i--){drawDongKe(colLabel[i]);}}
			function insertAfter(target, newNodeAfter){target.parentNode.insertBefore(newNodeAfter, target.nextSibling);}			
				]]></xsl:text></script></xsl:template><xsl:variable name="low" select="'abcdefghijklmnopqrstuvwxyzàáạảãâầấậẩẫăằắặẳẵèéẹẻẽêềếệểễìíịỉĩòóọỏõôồốộổỗơờớợởỡùúụủũưừứựửữỳýỵỷỹđ'" /><xsl:variable name="up" select="'ABCDEFGHIJKLMNOPQRSTUVWXYZÀÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬEÉÈẺẼẸÊỀẾỆỂỄÌÍỊỈĨÒÓỌỎÕÔỐỒỔỖỘƠỚỜỞỠỢUÚÙỦŨỤƯỨỪỬỮỰYÝỲỶỸỴĐ'" /><xsl:template name="DocTienInHoa"><xsl:param name="so_tien" /><xsl:variable name="so_sach" select="translate(normalize-space($so_tien), ',.', '')" /><xsl:variable name="chu_thuong"><xsl:call-template name="DocSoTien"><xsl:with-param name="so" select="number($so_sach)" /></xsl:call-template></xsl:variable><xsl:variable name="trim_chu" select="normalize-space($chu_thuong)" /><xsl:value-of select="translate(substring($trim_chu, 1, 1), $low, $up)" /><xsl:value-of select="substring($trim_chu, 2)" /><xsl:text> đồng.</xsl:text></xsl:template><xsl:template name="doc_chu_so"><xsl:param name="n" /><xsl:choose><xsl:when test="$n=0"> không</xsl:when><xsl:when test="$n=1"> một</xsl:when><xsl:when test="$n=2"> hai</xsl:when><xsl:when test="$n=3"> ba</xsl:when><xsl:when test="$n=4"> bốn</xsl:when><xsl:when test="$n=5"> năm</xsl:when><xsl:when test="$n=6"> sáu</xsl:when><xsl:when test="$n=7"> bảy</xsl:when><xsl:when test="$n=8"> tám</xsl:when><xsl:when test="$n=9"> chín</xsl:when></xsl:choose></xsl:template><xsl:template name="doc_nhom_3_so"><xsl:param name="n" /><xsl:param name="day_du" /><xsl:variable name="tram" select="floor($n div 100)" /><xsl:variable name="chuc" select="floor(($n mod 100) div 10)" /><xsl:variable name="donvi" select="$n mod 10" /><xsl:if test="$day_du = 1 or $tram &gt; 0"><xsl:call-template name="doc_chu_so"><xsl:with-param name="n" select="$tram" /></xsl:call-template><xsl:text> trăm</xsl:text></xsl:if><xsl:choose><xsl:when test="$chuc = 0 and $donvi &gt; 0 and ($day_du = 1 or $tram &gt; 0)"> lẻ</xsl:when><xsl:when test="$chuc = 1"> mười</xsl:when><xsl:when test="$chuc &gt; 1"><xsl:call-template name="doc_chu_so"><xsl:with-param name="n" select="$chuc" /></xsl:call-template><xsl:text> mươi</xsl:text></xsl:when></xsl:choose><xsl:choose><xsl:when test="$donvi = 1 and $chuc &gt; 1"> mốt</xsl:when><xsl:when test="$donvi = 5 and $chuc &gt; 0"> lăm</xsl:when><xsl:when test="$donvi &gt; 0"><xsl:call-template name="doc_chu_so"><xsl:with-param name="n" select="$donvi" /></xsl:call-template></xsl:when></xsl:choose></xsl:template><xsl:template name="DocSoTien"><xsl:param name="so" /><xsl:variable name="n" select="number($so)" /><xsl:choose><xsl:when test="$n = 0">Không đồng</xsl:when><xsl:otherwise><xsl:variable name="ty" select="floor($n div 1000000000)" /><xsl:variable name="trieu" select="floor(($n mod 1000000000) div 1000000)" /><xsl:variable name="nghin" select="floor(($n mod 1000000) div 1000)" /><xsl:variable name="dong" select="$n mod 1000" /><xsl:if test="$ty &gt; 0"><xsl:call-template name="doc_nhom_3_so"><xsl:with-param name="n" select="$ty" /><xsl:with-param name="day_du" select="0" /></xsl:call-template><xsl:text> tỷ</xsl:text></xsl:if><xsl:if test="$trieu &gt; 0"><xsl:call-template name="doc_nhom_3_so"><xsl:with-param name="n" select="$trieu" /><xsl:with-param name="day_du" select="boolean($ty &gt; 0)" /></xsl:call-template><xsl:text> triệu</xsl:text></xsl:if><xsl:if test="$nghin &gt; 0"><xsl:call-template name="doc_nhom_3_so"><xsl:with-param name="n" select="$nghin" /><xsl:with-param name="day_du" select="boolean($ty &gt; 0 or $trieu &gt; 0)" /></xsl:call-template><xsl:text> nghìn</xsl:text></xsl:if><xsl:if test="$dong &gt; 0"><xsl:call-template name="doc_nhom_3_so"><xsl:with-param name="n" select="$dong" /><xsl:with-param name="day_du" select="boolean($ty &gt; 0 or $trieu &gt; 0 or $nghin &gt; 0)" /></xsl:call-template></xsl:if></xsl:otherwise></xsl:choose></xsl:template><xsl:template name="TemplateBackground"><div class="textThaiSonRight"><div class="text">(Xuất bởi phần mềm EInvoice, Công ty TNHH Phát triển công nghệ Thái Sơn  - MST: 0101300842 - www.einvoice.vn)</div></div><xsl:if test="$isPhatHanh"><img class="phathanh" src="data:image/svg+xml;base64," /></xsl:if><div id="khungNenLogo" class="khungNenLogo draggable" style="position:relative;z-index:-2;"><img id="nenLogo" data-src="anhNenLogo" class="resizable logo nenLogo" data-style="styleNenLogo"><xsl:attribute name="src"><xsl:value-of select="$anhNenLogo" /></xsl:attribute><xsl:attribute name="style"><xsl:value-of select="$styleNenLogo" /></xsl:attribute></img></div><div id="khungNenHoaVan" class="khungNenHoaVan draggable" style="position:relative;z-index:-3;"><img id="anhNenHoaVan" data-src="anhHoaVan" class="anhNenHoaVan resizable" data-style="styleNenHoaVan"><xsl:attribute name="data-ma-anh"><xsl:value-of select="$maAnhNenThuVien" /></xsl:attribute><xsl:attribute name="src"><xsl:value-of select="$anhHoaVan" /></xsl:attribute><xsl:attribute name="style"><xsl:value-of select="$styleNenHoaVan " /></xsl:attribute></img></div><img id="anhVienHoaDon" class="anhVienHoaDon" data-src="anhVien"><xsl:attribute name="src"><xsl:value-of select="$anhVien " /></xsl:attribute><xsl:attribute name="style"><xsl:value-of select="$styleAnhVien" /></xsl:attribute></img></xsl:template><xsl:template name="TemplateLogo"><div id="khungLogo" class="khungLogo draggable" style="position: relative;"><img data-src="anhLogo" id="anhLogo" data-style="styleLogo" reduced="" width="87"><xsl:attribute name="class">
          logo resizable
